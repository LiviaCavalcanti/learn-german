# Sprachheft configuration — copy this file to `.env` and edit as needed.
# Every variable uses the SPRACHHEFT_ prefix. See src/sprachheft/config.py for
# the full list of settings and their defaults.
#
# The setup scripts (../setup.sh / ../setup.bat) create backend/.env from this
# template automatically on first run.

# ── LLM (exercise generation, tutor, rewrite, text import) ──────────────────
# "fake" runs fully offline with a deterministic stub — no model or API key
# needed, so the app works out of the box. Switch to a real model below when you
# want real generation (requires the `llm` extra: uv sync --extra llm).
SPRACHHEFT_LLM_MODEL=fake
#
# Local Ollama (free, runs on your machine — install from https://ollama.com):
#   SPRACHHEFT_LLM_MODEL=ollama/llama3.1
#   SPRACHHEFT_LLM_API_BASE=http://localhost:11434
#
# OpenAI:
#   SPRACHHEFT_LLM_MODEL=gpt-4o-mini
#   SPRACHHEFT_LLM_API_KEY=sk-...
#
# Anthropic:
#   SPRACHHEFT_LLM_MODEL=claude-3-5-sonnet-latest
#   SPRACHHEFT_LLM_API_KEY=...
#
# SPRACHHEFT_LLM_TEMPERATURE=0.3
# SPRACHHEFT_LLM_TIMEOUT=300

# ── Semantic vocabulary search ──────────────────────────────────────────────
# Empty = offline lexical (hashing) fallback. For a real local embedding model
# (recommended; requires the `embeddings` extra):
#   SPRACHHEFT_EMBEDDING_MODEL=fastembed:sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
# Changing this changes vector dimensions — rebuild via POST /vocab/reindex?rebuild=true
SPRACHHEFT_EMBEDDING_MODEL=

# ── Learner defaults ────────────────────────────────────────────────────────
SPRACHHEFT_DEFAULT_LEVEL=A2
SPRACHHEFT_DEFAULT_TARGET_LANG=de
SPRACHHEFT_DEFAULT_NATIVE_LANG=en

# ── Dev-server network binding ──────────────────────────────────────────────
# Set host to 0.0.0.0 to reach the app from other devices on your LAN /
# Tailscale network (e.g. your phone); pair with CORS_ALLOW_ALL=1 in that case.
SPRACHHEFT_HOST=127.0.0.1
SPRACHHEFT_PORT=8000
# SPRACHHEFT_CORS_ALLOW_ALL=0

# ── Daily reminders (local HH:MM) ───────────────────────────────────────────
SPRACHHEFT_ENABLE_REMINDERS=1
SPRACHHEFT_REMINDER_TIME=18:00

# ── Transcription (optional `transcribe` extra: yt-dlp + faster-whisper + ffmpeg)
SPRACHHEFT_ENABLE_TRANSCRIPTION=1
SPRACHHEFT_WHISPER_MODEL=base
