# Sprachheft backend configuration (git-ignored).
# Semantic vocabulary search — local multilingual embedding model (no API key).
SPRACHHEFT_EMBEDDING_MODEL=fastembed:sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# LLM for exercise generation (Ollama — local, no API key needed):
SPRACHHEFT_LLM_MODEL=ollama/qwen2.5
SPRACHHEFT_LLM_API_BASE=http://localhost:11434
# SPRACHHEFT_LLM_API_KEY=
